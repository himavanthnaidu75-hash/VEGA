# ── Broker ─────────────────────────────────────────────
BROKER=paper                    # Broker: paper, dhan, angel, zerodha
DHAN_CLIENT_ID=                 # Client ID for Dhan HQ
DHAN_ACCESS_TOKEN=              # Access Token for Dhan HQ
ANGEL_API_KEY=                  # SmartAPI Key
ANGEL_TOTP_SECRET=              # TOTP Secret for Angel login

# ── Capital & Risk ─────────────────────────────────────
TOTAL_CAPITAL=100000            # Initial trading capital in INR
MAX_RISK_PER_TRADE=0.01         # 1% risk per trade
MAX_OPEN_POSITIONS=5            # Max concurrent trades
MAX_DAILY_LOSS=0.03             # Halt trading if down 3%
MAX_DAILY_PROFIT=0.06           # Halt trading if up 6%
MIN_RR_RATIO=1.5                # Minimum Reward-to-Risk ratio
POSITION_SIZING=atr             # Sizing: atr, kelly, fixed
TRAILING_SL=true                # Enable/Disable trailing stop loss
TRAILING_SL_ATR_MULTIPLIER=1.5  # ATR multiplier for trailing SL

# ── Trading ────────────────────────────────────────────
TRADING_MODE=SIMULATION         # SIMULATION or LIVE
DEFAULT_TRADE_MODE=equities     # equities, fno, futures
ICT_MIN_CONFIDENCE=65           # 0-100 threshold for ICT gate
WATCHLIST=RELIANCE,TCS,INFY     # Comma-separated NSE symbols

# ── Notifications ──────────────────────────────────────
TELEGRAM_BOT_TOKEN=             # API Token from BotFather
TELEGRAM_CHAT_ID=               # Your Telegram Chat ID

# ── Security & Deployment ──────────────────────────────
KILL_TOKEN=vega_secret_kill     # Secret for manual kill switch API
JWT_SECRET=super_secret_jwt     # Secret for auth token signing
GOOGLE_CLIENT_ID=               # OAuth2 Client ID
GOOGLE_CLIENT_SECRET=           # OAuth2 Client Secret
PORT=8000                       # API Port
DB_PATH=vega.db                 # SQLite database path
